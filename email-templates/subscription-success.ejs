<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Welcome to Dealo</title>
    <style>
      :root {
        --green-dark: #1e4029;
        --green-primary: #2f6345;
        --green-light: #50876c;
        --green-soft: #d6f5e3;
        --text-dark: #2c2c2c;
        --text-muted: #777;
        --bg-base: #f4f4f4;
      }

      body {
        font-family: "Segoe UI", sans-serif;
        background: var(--bg-base);
        padding: 40px;
        color: var(--text-dark);
        margin: 0;
      }

      .container {
        max-width: 600px;
        margin: auto;
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
      }

      .header {
        background: var(--green-primary);
        padding: 20px;
        text-align: center;
      }

      .header img {
        max-width: 140px;
      }

      .content {
        padding: 30px;
        text-align: center;
      }

      h1 {
        font-size: 22px;
        color: var(--green-dark);
        margin-bottom: 16px;
      }

      p {
        font-size: 16px;
        line-height: 1.6;
        color: var(--text-dark);
      }

      .button {
        display: inline-block;
        padding: 12px 24px;
        background: var(--green-dark);
        color: white;
        border-radius: 6px;
        text-decoration: none;
        margin-top: 20px;
        font-weight: 500;
      }

      .button:hover {
        background: var(--green-primary);
      }

      .footer {
        font-size: 13px;
        color: var(--text-muted);
        text-align: center;
        padding: 20px;
        background: var(--green-soft);
      }
    </style>
  </head>
  <body>
    <div class="container">
      <!-- Header with Logo -->
      <div class="header">
        <img
          src="https://pub-734ce1bac5434727ba9692dacb3d7441.r2.dev/logos/dealo-new.png"
          alt="Dealo Logo"
        />
      </div>

      <!-- Content -->
      <div class="content">
        <h1>Hi Dealorian, welcome to Dealo 👋</h1>
        <p>
          Thanks for subscribing! You’ll be the one of the first to hear about
          product updates, freelance features, learning tools, and more.
        </p>

        <p>We’re excited to have you on board. 🚀</p>

        <a href="https://dealonetwork.com" class="button">Visit Dealo</a>
      </div>

      <!-- Footer -->
      <div class="footer">
        <p>
          © 2025 Dealo Talent Network · 23A Bashorun Okusanya Street, Lekki
          Phase 1, Lagos ·
          <a href="mailto:support@dealo.com">support@dealo.com</a>
        </p>
      </div>
    </div>
  </body>
</html>
